                      "type": "qcu",
                      "instruction": "<p>Qu’est-ce qui émet le plus de gaz à effet de serre ?</p>",
                      "hasShortProposals": false,
                      "proposals": [
                        {
                          "id": "0",
                          "content": "<p>La fabrication d’un smartphone</p>",
