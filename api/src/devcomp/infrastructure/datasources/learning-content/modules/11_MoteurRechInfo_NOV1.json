          "components": [
            {
              "type": "element",
              "element": {
                "id": "a205446e-9b8c-4dc2-b06e-d4176fc18a18",
                "type": "text",
                "tag": " ",
                "content": "<p>L'oncle d'Esther vient lui rendre visite à Grenoble ce week-end. Esther fait une recherche sur internet pour trouver un restaurant. Elle obtient la <strong>page de résultats</strong> suivante.</p><p>Observez cette page et répondez à la question.</p>"
              }
            },
            {
              "type": "element",
              "element": {
                "id": "56f620c3-1f5b-4cdb-a88b-f7ab24c26067",
                "type": "image",
                "url": "https://assets.pix.org/draft/modules/11_MoteurRechInfo_NOV1/resto_indien.png",
                "alt": "Page de résultat de recherche",
                "alternativeText": "<p>à compléter<br></p>",
                "legend": "",
                "licence": ""
              }
            },
            {
              "type": "element",
