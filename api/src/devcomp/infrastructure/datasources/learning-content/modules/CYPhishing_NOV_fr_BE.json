                "type": "custom",
                "title": "",
                "instruction": "",
                "functionalInstruction": "",
                "tagName": "message-conversation",
                "props": {
                  "conversationTitle": "Conversation de transition 1",
                  "messages": [
                    {
                      "userName": "Yvette",
                      "direction": "incoming",
                      "type": "Texte + Image",
                      "content": "Alors, qu’est-ce que tu me conseilles de faire avec ce message ?",
                      "image": {
                        "src": "https://assets.pix.org/modules/CYPhishingNov/msgyvette.svg",
                        "alt": "SMS : CREDIT BANQUE\u0003ATTENTION votre compte va être bloqué définitivement suite à des opérations suspectes. Cliquez immédiatement sur le lien pour éviter la désactivation : http://blocbanque.fr"
                      }
                    },
                    {
                      "userName": "Enzo",
                      "direction": "outgoing",
                      "type": "Texte",
                      "content": "Attention à ce message ! Si tu leur donnes ce qu’ils demandent, tu risques de te faire arnaquer et de perdre de l’argent."
                    },
                    {
                      "userName": "Yvette",
                      "direction": "incoming",
                      "type": "Texte",
                      "content": "Pourtant moi j’ai bien un compte dans cette banque, c’est bizarre."
                    },
                    {
                      "userName": "Enzo",
                      "direction": "outgoing",
                      "type": "Texte",
                      "content": "Oui les escrocs sont forts, ils arrivent même à se faire passer pour une banque ! 🤯 "
                    }
                  ]
                }
              }
            }
          ]
        },
