              "element": {
                "id": "e63a240b-41fe-47ba-9f7b-489ce500e120",
                "type": "qcu-discovery",
                "instruction": "<p>À partir de ces seules informations, pensez-vous être capable de trouver son mot de passe ?</p>",
                "hasShortProposals": false,
                "proposals": [
                  {
                    "id": "1",
                    "content": "<p>Oui.</p>",
                    "feedback": {
                      "diagnosis": "<p>Vraiment ? Pourtant, il semble difficile, voire impossible, de deviner un mot de passe à partir de si peu d’informations.</p>"
                    }
                  },
                  {
                    "id": "2",
                    "content": "<p>Non.</p>",
                    "feedback": {
                      "diagnosis": "<p>Effectivement, il semble difficile, voire impossible, de deviner un mot de passe à partir de si peu d’informations.</p>"
                    }
                  },
                  {
                    "id": "3",
                    "content": "<p>Je ne sais pas.</p>",
                    "feedback": {
                      "diagnosis": "<p>Pas si simple ! Il semble difficile, voire impossible, de deviner un mot de passe à partir de si peu d’informations.</p>"
                    }
                  }
                ],
                "solution": "2"
