          "components": [
            {
              "type": "element",
              "element": {
                "id": "ca6cabdb-6b85-45e1-b873-b809948eb628",
                "type": "text",
                "content": "<p>Maintenant, découvrez les autres touches utiles pour modifier du texte. ⌨️</p>"
              }
            }
