  "details": {
    "image": "https://assets.pix.org/modules/placeholder-details.svg",
    "description": "<p>Vous avez reçu une invitation pour une visioconférence et vous ne savez pas exactement quoi faire ?</p><p>Dans ce module, apprenez à rejoindre une réunion en visioconférence, préparer votre entrée et interagir simplement avec les autres participants.</p><br>",
    "duration": 10,
    "level": "novice",
    "objectives": [
      "<p>Rejoindre et quitter une visioconférence</p>",
      "<p>Ouvrir ou fermer son micro et sa caméra avant de rejoindre une visioconférence</p>",
      "<p>Identifier les participants et interagir de manière simple pendant la visioconférence</p>"
    ],
    "tabletSupport": "comfortable"
  },
