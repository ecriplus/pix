    "duration": 10,
    "level": "novice",
    "objectives": [
      "<p>Savoir que des médias en ligne peuvent être créés avec l'intelligence artificielle (IA)</p>",
      "<p>Connaître la notion de deepfake (hypertrucage)</p>",
      "<p>Repérer les intentions des auteurs de deepfakes (hypertrucages)</p>"
    ],
    "tabletSupport": "inconvenient"
