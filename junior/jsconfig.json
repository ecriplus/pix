{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": false,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "junior/*": ["./app/*", "./*"]
    }
  },
  "include": ["app/**/*.js", "app/**/*.gjs", "tests/**/*.js", "config/**/*.js", "mirage/**/*.js"],
  "exclude": ["node_modules", "tmp", "dist", "coverage"]
}
