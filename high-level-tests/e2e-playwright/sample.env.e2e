# Configuration for e2e tests

# Pix API
PIX_API_PORT=3323
AUTH_SECRET='secret'

# Pix Apps
PIX_APP_URL=http://localhost:4200
PIX_APP_FR_URL=https://app.dev.pix.fr
PIX_APP_ORG_URL=https://app.dev.pix.org

PIX_ORGA_URL=http://localhost:4201
PIX_ORGA_FR_URL=https://orga.dev.pix.fr
PIX_ORGA_ORG_URL=https://orga.dev.pix.org

PIX_CERTIF_URL=http://localhost:4203
PIX_CERTIF_FR_URL=https://certif.dev.pix.fr
PIX_CERTIF_ORG_URL=https://certif.dev.pix.org

PIX_ADMIN_URL=http://localhost:4202
PIX_ADMIN_FR_URL=https://admin.dev.pix.fr

# Postgres databases
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pix_test
DATAMART_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datamart_test
DATAWAREHOUSE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datawarehouse_test
JOBS_DATABASE_URL=postgresql://postgres@localhost/pix_test

# Redis
REDIS_URL=redis://localhost:6379

# Learning content
LCMS_API_URL=<fill_me>
LCMS_API_KEY=<fill_me>
LCMS_API_RELEASE_ID=2360?forCI

# Playwright config
# set to true when you launch by yourself locally the front apps
# makes the dev loop faster instead of letting playwright relaunch the whole thing over and over again
REUSE_EXISTING_APPS=false
