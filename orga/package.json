{
  "name": "pix-orga",
  "version": "5.406.0",
  "private": false,
  "description": "Plateforme en ligne de gestion de campagne d'évaluation",
  "license": "AGPL-3.0",
  "author": "GIP Pix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1024pix/pix.git"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "files": [],
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf tmp dist node_modules",
    "lint": "run-s -clns 'lint:(hbs|js|scss|translations)'",
    "lint:fix": "run-s -clns 'lint:(hbs|js|scss|translations):fix'",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache --cache-strategy content",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:js:uncached": "eslint .",
    "lint:scss": "stylelint app/styles/*.scss 'app/styles/**/*.scss'",
    "lint:scss:fix": "npm run lint:scss -- --fix",
    "lint:translations": "eslint --format node_modules/eslint-plugin-i18n-json/formatter.js translations",
    "lint:translations:fix": "npm run lint:translations -- --fix",
    "preinstall": "npx check-engine",
    "dev": "vite",
    "start": "vite",
    "test": "ember exam --path dist --config-file ./testem.cjs",
    "test:ci": "vite build --mode test && ember exam --path dist --config-file ./testem.cjs --split=$CIRCLE_NODE_TOTAL --partition=$((1 + CIRCLE_NODE_INDEX))",
    "test:lint": "npm test && npm run lint"
  },
  "devDependencies": {
    "@1024pix/ember-testing-library": "^3.0.27",
    "@1024pix/eslint-plugin": "^2.1.19",
    "@1024pix/pix-ui": "60.10.1",
    "@1024pix/stylelint-config": "^5.1.37",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@ember-intl/v1-compat": "^1.0.2",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.17.2",
    "@embroider/vite": "^1.7.2",
    "@faker-js/faker": "^10.0.0",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "@rollup/plugin-babel": "^7.0.0",
    "@testing-library/dom": "^10.4.1",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "chart.js": "^4.4.9",
    "chartjs-adapter-dayjs-4": "^1.0.4",
    "dayjs": "^1.11.13",
    "decorator-transforms": "^2.3.1",
    "ember-auto-import": "^2.12.1",
    "ember-cli": "^6.12.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-htmlbars": "^7.0.0",
    "ember-click-outside": "^6.1.1",
    "ember-cookies": "^1.3.0",
    "ember-data": "^5.3.3",
    "ember-exam": "^10.1.0",
    "ember-inflector": "^6.0.0",
    "ember-intl": "^8.0.3",
    "ember-lifeline": "^7.0.0",
    "ember-load-initializers": "^3.0.1",
    "ember-metrics": "^2.0.0",
    "ember-page-title": "^9.0.2",
    "ember-qunit": "^9.0.3",
    "ember-resolver": "^13.1.0",
    "ember-simple-auth": "^8.0.0",
    "ember-source": "^6.11.0",
    "ember-template-lint": "^7.9.3",
    "ember-template-lint-plugin-prettier": "^5.0.0",
    "ember-truth-helpers": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^13.0.0",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^17.0.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "jwt-decode": "^4.0.0",
    "miragejs": "^0.1.48",
    "npm-run-all2": "^8.0.0",
    "p-queue": "^9.0.0",
    "patternomaly": "^1.3.2",
    "postcss": "^8.5.10",
    "postcss-url": "^10.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "qunit": "^2.23.1",
    "qunit-dom": "^3.4.0",
    "sass-embedded": "^1.99.0",
    "showdown": "^2.1.0",
    "sinon": "^21.0.0",
    "striptags": "^3.2.0",
    "stylelint": "^17.5.0",
    "vite": "^8.0.0",
    "xss": "^1.0.15"
  },
  "overrides": {
    "ember-dayjs": {
      "ember-source": "$ember-source"
    },
    "flatted": ">=3.4.2",
    "handlebars": ">=4.7.9",
    "@xmldom/xmldom": ">=0.8.13"
  },
  "engines": {
    "node": "^24.15.0"
  },
  "ember": {
    "edition": "octane"
  }
}
