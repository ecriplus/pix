{
  "name": "mon-pix",
  "version": "5.435.0",
  "private": false,
  "description": "Plateforme d'évaluation et de certification des compétences numériques",
  "license": "AGPL-3.0",
  "author": "GIP Pix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1024pix/pix.git"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "files": [],
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "scripts": {
    "clean": "rm -rf tmp dist node_modules",
    "lint": "run-s -clns 'lint:(hbs|js|scss|translations)'",
    "lint:fix": "run-s -clns 'lint:(hbs|js|scss|translations):fix'",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache --cache-strategy content",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:js:uncached": "eslint .",
    "lint:scss": "stylelint 'app/**/*.scss'",
    "lint:scss:fix": "npm run lint:scss -- --fix",
    "lint:translations": "eslint --format node_modules/eslint-plugin-i18n-json/formatter.js translations",
    "lint:translations:fix": "npm run lint:translations -- --fix",
    "build": "ember build --environment $BUILD_ENVIRONMENT",
    "preinstall": "npx check-engine",
    "dev": "ember serve --proxy http://localhost:3000",
    "start": "ember serve --proxy http://localhost:3000 --live-reload false",
    "test": "ember test",
    "test:ci": "npx ember exam --path=./dist --split=$CIRCLE_NODE_TOTAL --partition=$((1 + CIRCLE_NODE_INDEX))",
    "test:lint": "npm test && npm run lint",
    "test:watch": "ember exam --serve --reporter dot"
  },
  "devDependencies": {
    "@1024pix/ember-api-actions": "^1.1.0",
    "@1024pix/ember-testing-library": "^3.0.27",
    "@1024pix/epreuves-components": "^4.6.2",
    "@1024pix/eslint-plugin": "^2.1.19",
    "@1024pix/pix-ui": "^61.1.0",
    "@1024pix/stylelint-config": "^5.1.37",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@ember-data/json-api": "^5.8.2",
    "@ember-data/model": "^5.8.2",
    "@ember-intl/v1-compat": "^1.0.9",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^3.1.1",
    "@ember/test-helpers": "^5.4.2",
    "@embroider/compat": "^3.9.4",
    "@embroider/core": "^3.5.10",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/util": "^1.13.5",
    "@embroider/webpack": "^4.1.2",
    "@formatjs/intl": "^4.1.11",
    "@glimmer/component": "^1.1.2",
    "@sentry/ember": "^10.53.1",
    "@testing-library/user-event": "^14.6.1",
    "buffer": "^6.0.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "^7.0.0",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-autoprefixer": "^2.0.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-clipboard": "^1.3.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-deprecation-workflow": "^4.0.1",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-mirage": "^3.0.4",
    "ember-cli-sass": "^11.0.1",
    "ember-cookies": "^1.3.0",
    "ember-data": "^5.8.2",
    "ember-dayjs": "^0.12.4",
    "ember-element-helper": "^0.8.8",
    "ember-exam": "^10.1.0",
    "ember-intl": "^8.2.4",
    "ember-keyboard": "^9.0.4",
    "ember-lifeline": "^7.0.0",
    "ember-load-initializers": "^3.0.1",
    "ember-metrics": "^2.0.0",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-responsive": "^5.0.0",
    "ember-simple-auth": "^8.3.0",
    "ember-source": "^6.12.0",
    "ember-template-imports": "^4.4.0",
    "ember-template-lint": "^7.9.3",
    "ember-template-lint-plugin-prettier": "^5.0.0",
    "ember-test-selectors": "^7.1.0",
    "ember-truth-helpers": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^13.3.0",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^17.6.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-yaml": "^4.1.1",
    "jwt-decode": "^4.0.0",
    "loader.js": "^4.7.0",
    "lodash": "^4.18.1",
    "miragejs": "^0.1.48",
    "npm-run-all2": "^9.0.0",
    "p-queue": "^9.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ember-template-tag": "^2.1.6",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.1",
    "sass": "^1.99.0",
    "showdown": "^2.1.0",
    "sinon": "^22.0.0",
    "stylelint": "^17.11.1",
    "stylelint-order": "^8.1.1",
    "tracked-built-ins": "^4.1.2",
    "tracked-toolbox": "^3.0.0",
    "webpack": "^5.106.2",
    "xss": "^1.0.15"
  },
  "overrides": {
    "@xmldom/xmldom": ">=0.9.10",
    "ember-dayjs": {
      "ember-source": "$ember-source"
    },
    "flatted": ">=3.4.2",
    "handlebars": ">=4.7.9",
    "braces": ">=3.0.3"
  },
  "engines": {
    "node": "^24.15.0"
  },
  "ember": {
    "edition": "octane"
  }
}
